# Stage-Environment Konfiguration
# Kopiere zu .env.stage und passe an. .env.stage darf NICHT comitted werden.

# Datenbank (eigene Stage-DB)
POSTGRES_USER=finance_stage
POSTGRES_PASSWORD=CHANGE_ME_STAGE
POSTGRES_DB=finance_stage

# Sicherheit (eigene Stage-Secrets, NIE Prod-Secrets verwenden)
JWT_SECRET=CHANGE_ME_STAGE_JWT_MIN_32_ZEICHEN
ENCRYPTION_KEY=CHANGE_ME_STAGE_ENCRYPTION_BASE64
REDIS_PASSWORD=CHANGE_ME_STAGE_REDIS

# Stage-Admin (wird vom Anonymisierungs-Skript auf admin@example.test gesetzt)
ADMIN_EMAIL=admin@example.test
ADMIN_PASSWORD=stage123

# Stage-Ports (abweichend von Production um Konflikte zu vermeiden)
# DB:        5433 (Prod: 5432)
# Backend:   8001 (Prod: 8000)
# Frontend:  5174 (Prod: 5173)
FRONTEND_PORT=5174
BACKEND_PORT=8001

# Frontend-URL (lokal)
FRONTEND_URL=http://localhost:5174
CORS_ORIGINS=http://localhost:5174

# Stage darf KEINE externen Mails versenden
# (SMTP_HOST wird im docker-compose.stage.yml hart auf "" gesetzt)
