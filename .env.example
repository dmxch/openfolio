# OpenFolio Konfiguration
# Kopiere diese Datei zu .env und passe die Werte an
# Oder nutze ./init.sh für automatische Konfiguration

# Datenbank
POSTGRES_USER=openfolio
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=openfolio

# Sicherheit
JWT_SECRET=CHANGE_ME_MIN_32_ZEICHEN
ENCRYPTION_KEY=CHANGE_ME_BASE64_32_BYTE
REDIS_PASSWORD=CHANGE_ME_RANDOM

# API Docs (auf true setzen für Entwicklung)
# ENABLE_API_DOCS=true

# Initialer Admin (nur beim ersten Start nötig)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=CHANGE_ME

# Ports
FRONTEND_PORT=5173
BACKEND_PORT=8000

# Eigene Domain (für Reverse Proxy Setup)
# CORS_ORIGINS=https://deine-domain.com
# FRONTEND_URL=https://deine-domain.com

# Optional
# FMP_API_KEY=dein_api_key
# LEGACY_ENCRYPTION_KEY=nur_setzen_wenn_migration_von_alter_version
