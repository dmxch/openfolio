# OpenFolio Konfiguration
# Kopiere diese Datei zu .env und passe die Werte an
# Oder nutze ./init.sh für automatische Konfiguration

# Datenbank
POSTGRES_USER=openfolio
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=openfolio

# Sicherheit
JWT_SECRET=CHANGE_ME_MIN_32_ZEICHEN
ENCRYPTION_KEY=CHANGE_ME_BASE64_32_BYTE
REDIS_PASSWORD=CHANGE_ME_RANDOM

# API Docs (auf true setzen für Entwicklung)
# ENABLE_API_DOCS=true

# Initialer Admin (nur beim ersten Start nötig — nach Erstellung aus .env entfernen)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=CHANGE_ME

# Ports
FRONTEND_PORT=5173
BACKEND_PORT=8000
# UPTIME_KUMA_PORT=3001

# Eigene Domain (für Reverse Proxy Setup)
# CORS_ORIGINS=https://deine-domain.com
# FRONTEND_URL=https://deine-domain.com

# Externe APIs:
# FRED, FMP und Finnhub API-Keys werden NICHT mehr ueber Umgebungsvariablen
# konfiguriert. Jeder User traegt seine eigenen Keys nach dem Login unter
# Einstellungen → Integrationen ein. Die Keys werden verschluesselt in der
# Datenbank gespeichert.
# - FRED:    https://fred.stlouisfed.org/docs/api/api_key.html  (gratis)
# - FMP:     https://site.financialmodelingprep.com/developer/docs  (gratis 250 calls/Tag)
# - Finnhub: https://finnhub.io/register  (gratis 60 calls/Min)

# E-Mail (optional — für Alert-Benachrichtigungen)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASSWORD=smtp_passwort

# Monitoring (optional — nur für docker-compose.monitoring.yml)
# GRAFANA_USER=admin
# GRAFANA_PASSWORD=CHANGE_ME

# Legacy (nur bei Migration von alter Version)
# LEGACY_ENCRYPTION_KEY=nur_setzen_wenn_migration_von_alter_version
